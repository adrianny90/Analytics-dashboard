# Optional. Get a free key at https://finnhub.io/register to enable true
# real-time websocket streaming for the SPY/QQQ/IWM index proxies.
# Without it, the app still works, falling back to polling yfinance every
# POLL_INTERVAL_SECONDS.
FINNHUB_API_KEY=

CORS_ORIGINS=["http://localhost:3000"]
POLL_INTERVAL_SECONDS=5
