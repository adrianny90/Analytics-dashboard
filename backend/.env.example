# Optional but recommended given the size of the watchlist. Get a free key
# at https://finnhub.io/register (no card needed) to enable:
#   1. True real-time websocket streaming for the SPY/QQQ/IWM index proxies.
#   2. A REST fallback for individual equity quotes when Yahoo Finance is
#      rate-limited or blocked (marks the quote "stale": true).
# Without it, the app still works, relying solely on yfinance + cached data.
FINNHUB_API_KEY=

CORS_ORIGINS=["http://localhost:3000"]

# Yahoo's unofficial API rate-limits aggressively, especially with a
# watchlist this size (99 symbols). These defaults are tuned to stay under
# that limit; raise POLL_INTERVAL_SECONDS or YFINANCE_REQUEST_SPACING_SECONDS
# further if you still see "Too Many Requests" in the logs.
POLL_INTERVAL_SECONDS=45
YFINANCE_REQUEST_SPACING_SECONDS=1.2
RATE_LIMIT_COOLDOWN_SECONDS=180

# How long a successfully fetched chart is considered fresh before
# refetching. Failed refreshes still serve the last cached result regardless
# of this TTL.
HISTORY_CACHE_TTL_SECONDS=300
